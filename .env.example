# MongoDB Atlas M0 — server-only, never expose to client
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/lucifer-cafe?retryWrites=true&w=majority

# NextAuth.js v5 (Auth.js) — generate secret with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Cloudinary — server-only credentials for signed operations / deletes
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Cloudinary — public cloud name (BUILD-time; needed to render product image URLs).
# Uploads are signed server-side via /api/upload, so no public upload preset is used.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
